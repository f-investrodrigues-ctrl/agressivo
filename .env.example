# Copy to .env and adjust. Never commit .env.

# Logging: INFO, DEBUG, WARNING
AGRESSIVO_LOG_LEVEL=INFO

# Default exchange id for ccxt (public OHLCV needs no keys)
AGRESSIVO_EXCHANGE=binance

# Comma-separated symbols as CCXT unified (spot default)
AGRESSIVO_SYMBOLS=BTC/USDT,ETH/USDT

# OHLCV timeframe: 1m, 5m, 15m, 1h, 4h, 1d
AGRESSIVO_TIMEFRAME=1h

# Core v1 — filtro de tendência (close > MA; alinhado a breakout_signals)
# AGRESSIVO_CORE_TREND_MA=120
# AGRESSIVO_CORE_REQUIRE_ABOVE_TREND=true

# Optional paths
AGRESSIVO_CACHE_DIR=data/cache

# Paper trading (JSON local)
AGRESSIVO_PAPER_STATE_PATH=data/paper_state.json

# ccxt options.defaultType: spot | swap | future (default spot)
AGRESSIVO_EXCHANGE_MARKET_TYPE=spot

# Satélite — calendário JSON (veto_core bloqueia novo long no Paper; opcional)
# AGRESSIVO_SATELLITE_CATALOG_PATH=data/satellite/catalog.example.json

# Ledger de ordens (JSON lines)
AGRESSIVO_ORDER_LEDGER_PATH=data/order_ledger.jsonl

# false = apenas dry-run registado no ledger; true + --execute permite envio real
AGRESSIVO_EXECUTE_ORDERS=false

# Retries/transientes (create_order e fetch opcional)
AGRESSIVO_EXECUTE_ORDER_RETRIES=4
AGRESSIVO_EXECUTE_ORDER_RETRY_BASE_SEC=0.45

# Após submit, tentar fetch_order e gravar exchange_fetch_confirm no ledger
AGRESSIVO_EXECUTE_ORDER_FETCH_CONFIRM=false

# Opcional: leitura de saldo spot (ccxt) — nunca committar valores reais
# AGRESSIVO_EXCHANGE_API_KEY=
# AGRESSIVO_EXCHANGE_API_SECRET=
# AGRESSIVO_EXCHANGE_PASSWORD=
# AGRESSIVO_EXCHANGE_SANDBOX=false
